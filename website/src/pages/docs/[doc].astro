---
import "../../styles/global.css";
import { groupedDocs, loadDocs } from "../../lib/docs";
import { marked } from "marked";
import { createHighlighter } from "shiki";
import markedShiki from "marked-shiki";
import path from "node:path";
const BASE = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const docHref = (slug: string) => `${BASE}docs/${slug}`;
const withBase = (p: string) => `${BASE}${p.replace(/^\/+/, "")}`;

const resolveAssetPath = (docKey: string, rawUrl: string) => {
  if (
    !rawUrl ||
    rawUrl.startsWith("http://") ||
    rawUrl.startsWith("https://") ||
    rawUrl.startsWith("mailto:") ||
    rawUrl.startsWith("data:") ||
    rawUrl.startsWith("#")
  ) {
    return rawUrl;
  }
  if (rawUrl.startsWith("/")) return withBase(rawUrl);
  const baseDir = docKey.startsWith("docs/") ? "docs" : "";
  return withBase(path.posix.normalize(path.posix.join(baseDir, rawUrl)));
};

const rewriteRelativeLinks = (body: string, docKey: string) => {
  let out = body;
  out = out.replace(/(!?\[[^\]]*\]\()([^)]+)(\))/g, (_m, p1, url, p3) => {
    return `${p1}${resolveAssetPath(docKey, String(url).trim())}${p3}`;
  });
  out = out.replace(/(<(?:img|a)[^>]*(?:src|href)=["'])([^"']+)(["'][^>]*>)/gi, (_m, p1, url, p3) => {
    return `${p1}${resolveAssetPath(docKey, String(url).trim())}${p3}`;
  });
  return out;
};

const shiki = await createHighlighter({
  themes: ["github-dark-default"],
  langs: [
    "javascript", 
    "typescript", 
    "css", 
    "html", 
    "rust", 
    "bash", 
    "shellscript", 
    "powershell", 
    "json", 
    "toml", 
    "yaml", 
    "markdown"
  ],
});

marked.use(
  markedShiki({
    highlight(code, lang, props) {
      return shiki.codeToHtml(code, {
        lang: lang || "text",
        theme: "github-dark-default",
        meta: { __raw: props.join(" ") },
      });
    },
  })
);

export async function getStaticPaths() {
  const docs = await loadDocs();
  return docs.map((doc) => ({
    params: { doc: doc.slug },
  }));
}

const docs = await loadDocs();
const grouped = groupedDocs(docs);
const requestedSlug = Astro.params.doc;
const current = docs.find((d) => d.slug === requestedSlug) ?? docs[0];

const searchIndex = docs.flatMap(doc => 
  doc.sections.map((s, i) => ({
    title: s.title,
    bodySnippet: s.body.substring(0, 120).replace(/\n/g, " ") + (s.body.length > 120 ? "..." : ""),
    url: `${BASE}docs/${doc.slug}#sec-${doc.slug}-${i}`,
    docLabel: doc.label
  }))
);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{current.label} | LUPA Docs</title>
    <meta name="description" content="LUPA documentation loaded directly from markdown files in the repository." />
  </head>
  <body>
    <main class="lupa-docs-layout">
      <header class="lupa-docs-header">
        <button
          class="lupa-docs-menu-btn"
          type="button"
          aria-label="Open documentation navigation"
          aria-controls="docs-sidebar"
          aria-expanded="false"
          data-docs-menu-toggle
        >
          <span></span>
          <span></span>
          <span></span>
        </button>
        <a
          class="brand-mark"
          href={`${BASE}docs`}
          aria-label="LUPA documentation"
          title="LUPA Docs"
        >
          <span class="brand-dot" aria-hidden="true"></span>
          <span class="brand-text">LUPA DOCS</span>
        </a>
        <div class="lupa-docs-search-wrap">
          <input id="docs-search" class="lupa-docs-search" type="text" placeholder="Search docs..." autocomplete="off" />
          <div id="docs-search-results" class="lupa-search-results" style="display: none;"></div>
        </div>
        <div class="lupa-docs-header-actions">
          
          <a href={BASE} class="lupa-docs-header-link">Landing</a>

          <a href="https://github.com/RobinsonBeato/Universal-Local-AI-Indexer" class="lupa-docs-header-link is-primary">GitHub</a>
        </div>
      </header>

      <div class="lupa-docs-overlay" data-docs-overlay></div>

      <aside class="lupa-docs-sidebar" id="docs-sidebar" aria-label="Documentation navigation">
        <div class="lupa-docs-side-head">Navigation</div>
        <div class="lupa-docs-primary">
          {docs.slice(0, 5).map((doc) => (
            <a class={`lupa-docs-primary-item ${doc.slug === current.slug ? "is-current" : ""}`} href={docHref(doc.slug)}>{doc.label}</a>
          ))}
        </div>

        <details open class="lupa-docs-group">
          <summary>Getting started</summary>
          <div class="lupa-docs-items">
            {grouped.start.map((doc) => (
              <a class={`lupa-docs-item ${doc.slug === current.slug ? "is-active" : ""}`} href={docHref(doc.slug)}>{doc.label}</a>
            ))}
          </div>
        </details>

        <details open class="lupa-docs-group">
          <summary>Core system</summary>
          <div class="lupa-docs-items">
            {grouped.core.map((doc) => (
              <a class={`lupa-docs-item ${doc.slug === current.slug ? "is-active" : ""}`} href={docHref(doc.slug)}>{doc.label}</a>
            ))}
          </div>
        </details>

        <details open class="lupa-docs-group">
          <summary>Planning and ops</summary>
          <div class="lupa-docs-items">
            {grouped.planning.map((doc) => (
              <a class={`lupa-docs-item ${doc.slug === current.slug ? "is-active" : ""}`} href={docHref(doc.slug)}>{doc.label}</a>
            ))}
          </div>
        </details>

        <details open class="lupa-docs-group">
          <summary>Legal</summary>
          <div class="lupa-docs-items">
            {grouped.legal.map((doc) => (
              <a class={`lupa-docs-item ${doc.slug === current.slug ? "is-active" : ""}`} href={docHref(doc.slug)}>{doc.label}</a>
            ))}
          </div>
        </details>
      </aside>

      <section class="lupa-docs-content">
        <div class="lupa-docs-titlebar">
          <p class="lupa-docs-kicker">{current.key}</p>
          <h1>{current.label}</h1>
          <p>{current.lines} lines · {current.sections.length} sections</p>
        </div>
        <div class="lupa-docs-sections">
          {current.sections.map(async (s, i) => {
            const htmlContent = await marked.parse(rewriteRelativeLinks(s.body, current.key));
            return (
              <section class="lupa-docs-section" id={`sec-${current.slug}-${i}`}>
                <h2 class="text-2xl font-bold tracking-tight mb-4">{s.title}</h2>
                <div class="prose prose-invert prose-p:text-gray-300 prose-headings:text-gray-100 prose-a:text-indigo-400 hover:prose-a:text-indigo-300 prose-code:text-indigo-300 max-w-none shiki-container" set:html={htmlContent} />
              </section>
            );
          })}
        </div>
      </section>

      <aside class="lupa-docs-right" aria-label="Document outline">
        <h3>On this page</h3>
        <div class="lupa-docs-outline">
          {current.sections.map((s, i) => (
            <a href={`#sec-${current.slug}-${i}`}>{s.title}</a>
          ))}
        </div>
      </aside>
    </main>

    <script is:inline define:vars={{ searchIndex }}>
      const input = document.getElementById("docs-search");
      const resultsContainer = document.getElementById("docs-search-results");
      const menuToggle = document.querySelector("[data-docs-menu-toggle]");
      const sidebar = document.getElementById("docs-sidebar");
      const overlay = document.querySelector("[data-docs-overlay]");
      const closeDocsMenu = () => {
        document.body.classList.remove("docs-nav-open");
        if (menuToggle) menuToggle.setAttribute("aria-expanded", "false");
      };
      const openDocsMenu = () => {
        document.body.classList.add("docs-nav-open");
        if (menuToggle) menuToggle.setAttribute("aria-expanded", "true");
      };

      if (menuToggle && sidebar && overlay) {
        menuToggle.addEventListener("click", () => {
          if (document.body.classList.contains("docs-nav-open")) {
            closeDocsMenu();
          } else {
            openDocsMenu();
          }
        });

        overlay.addEventListener("click", closeDocsMenu);
        sidebar.querySelectorAll("a").forEach((link) => {
          link.addEventListener("click", () => {
            if (window.innerWidth <= 860) closeDocsMenu();
          });
        });

        window.addEventListener("resize", () => {
          if (window.innerWidth > 860) closeDocsMenu();
        });
      }
      
      if (input && resultsContainer) {
        input.addEventListener("input", () => {
          const q = input.value.toLowerCase().trim();
          if (!q) {
            resultsContainer.style.display = "none";
            return;
          }
          
          const hits = searchIndex.filter(item => 
            item.title.toLowerCase().includes(q) || 
            item.bodySnippet.toLowerCase().includes(q) ||
            item.docLabel.toLowerCase().includes(q)
          ).slice(0, 8); // Top 8 results
          
          if (hits.length === 0) {
            resultsContainer.innerHTML = '<div class="lupa-search-empty">No results found</div>';
          } else {
            resultsContainer.innerHTML = hits.map(hit => `
              <a href="${hit.url}" class="lupa-search-result-item">
                <div class="lupa-search-result-title">${hit.title} <span class="lupa-search-result-badge">${hit.docLabel}</span></div>
                <div class="lupa-search-result-snippet">${hit.bodySnippet}</div>
              </a>
            `).join("");
          }
          resultsContainer.style.display = "block";
        });

        // Hide dropdown when clicking outside
        document.addEventListener("click", (e) => {
          if (!input.contains(e.target) && !resultsContainer.contains(e.target)) {
            resultsContainer.style.display = "none";
          }
        });
        
        // Hide dropdown and clear input when a result is clicked
        resultsContainer.addEventListener("click", (e) => {
          if (e.target.closest("a")) {
            resultsContainer.style.display = "none";
            input.value = "";
          }
        });
        
        // Show dropdown on input focus if there is text
        input.addEventListener("focus", () => {
          if (input.value.trim().length > 0) {
            resultsContainer.style.display = "block";
          }
        });
      }
    </script>
  </body>
</html>
