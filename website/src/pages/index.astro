---
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>LUPA | Instant Local Search</title>
    <meta
      name="description"
      content="Offline-first local search app built in Rust. Fast indexing and retrieval with Tantivy + SQLite + Rayon."
    />
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js" defer></script>
  </head>
  <body>
    <main class="landing">
      <a
        class="brand-mark"
        href="https://github.com/RobinsonBeato/Universal-Local-AI-Indexer"
        aria-label="LUPA project"
        title="LUPA"
      >
        <span class="brand-dot" aria-hidden="true"></span>
        <span class="brand-text">LUPA</span>
        
      </a>

      <video
        class="bg-video"
        data-bg-video
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        aria-hidden="true"
      >
        <source src="/video/test1.loop.mp4" type="video/mp4" />

      </video>
      <div class="video-loop-fade" aria-hidden="true"></div>
      <div class="video-overlay" aria-hidden="true"></div>
      <div class="video-top-mask" aria-hidden="true"></div>
      <div class="video-top-corner-cover" aria-hidden="true"></div>
      <div class="video-logo-mask" aria-hidden="true"></div>
      <div class="video-watermark-cover" aria-hidden="true"></div>

      <header class="top-controls">
        <a
          class="doc-btn"
          href="/docs"
          aria-label="Open documentation"
          title="Documentation"
        >
          Documentation
        </a>
       
      </header>

      <section class="hero" aria-label="LUPA hero">
        
        <h1 class="hero-title reveal">
          <span class="grad-a">Clarity.</span>
          <span class="solid">Focus.</span>
          <span class="grad-b">Impact.</span>
        </h1>

        <p class="hero-product reveal">LUPA Desktop Search</p>
        <p class="hero-sub reveal-delay">
          We turn complex file systems into effortless local search experiences.
        </p>
      </section>

      <nav class="bottom-ctas reveal-bottom" aria-label="Primary actions">
        <a class="bottom-btn primary" href="https://github.com/RobinsonBeato/Universal-Local-AI-Indexer/releases/tag/v0.1.0">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path fill="currentColor" d="M12 3a1 1 0 0 1 1 1v8.59l2.3-2.3a1 1 0 1 1 1.4 1.42l-4 3.98a1 1 0 0 1-1.4 0l-4-3.98a1 1 0 1 1 1.4-1.42L11 12.59V4a1 1 0 0 1 1-1m-7 14a1 1 0 0 1 1 1v1h12v-1a1 1 0 1 1 2 0v2a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-2a1 1 0 0 1 1-1" />
          </svg>
          <span>Download</span>
        </a>
        <a class="bottom-btn" href="https://github.com/RobinsonBeato/Universal-Local-AI-Indexer">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path fill="currentColor" d="M12 .5a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2.2c-3.3.7-4-1.4-4-1.4c-.6-1.3-1.3-1.7-1.3-1.7c-1-.7.1-.7.1-.7c1.1.1 1.7 1.2 1.7 1.2c1 .1.1 2 2.8 1.4c.1-.7.4-1.1.7-1.3c-2.7-.3-5.5-1.3-5.5-6A4.7 4.7 0 0 1 5.2 9a4.4 4.4 0 0 1 .1-3.2s1-.3 3.3 1.2a11.2 11.2 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2a4.4 4.4 0 0 1 .1 3.2a4.7 4.7 0 0 1 1.2 3.3c0 4.7-2.8 5.7-5.5 6c.4.3.8 1 .8 2.1v3.1c0 .3.2.7.8.6A12 12 0 0 0 12 .5" />
          </svg>
          <span>GitHub</span>
        </a>
      </nav>
    </main>

    <script>
      const runHero = (gsap) => {
        gsap.fromTo(
          ".reveal",
          { opacity: 0, y: 24 },
          { opacity: 1, y: 0, duration: 1.15, ease: "power3.out" }
        );
        gsap.fromTo(
          ".reveal-delay",
          { opacity: 0, y: 14 },
          { opacity: 1, y: 0, duration: 1.05, delay: 0.2, ease: "power3.out" }
        );
        gsap.fromTo(
          ".reveal-bottom",
          { opacity: 0, y: 16 },
          { opacity: 1, y: 0, duration: 0.9, delay: 0.45, ease: "power2.out" }
        );

        /** @type {HTMLVideoElement|null} */
        const bgVideo = document.querySelector("[data-bg-video]");
        /** @type {HTMLElement|null} */
        const overlay = document.querySelector(".video-loop-fade");
        if (bgVideo && overlay) {
          const fadeOutSeconds = 0.65;
          const holdBlackSeconds = 2.0;
          const fadeInSeconds = 0.85;

          const runBlackCycle = () => {
            gsap.to(overlay, {
              opacity: 0.92,
              duration: fadeOutSeconds,
              ease: "power2.inOut",
              onComplete: () => {
                gsap.delayedCall(holdBlackSeconds, () => {
                  gsap.to(overlay, {
                    opacity: 0,
                    duration: fadeInSeconds,
                    ease: "power2.inOut"
                  });
                });
              }
            });
          };

          const scheduleByDuration = () => {
            const d = bgVideo.duration;
            if (!Number.isFinite(d) || d <= 0) return;
            // Start fade shortly before each natural loop boundary.
            const delay = Math.max(0.1, d - fadeOutSeconds - 0.04);
            const tick = () => {
              runBlackCycle();
              gsap.delayedCall(d, tick);
            };
            gsap.delayedCall(delay, tick);
          };

          if (Number.isFinite(bgVideo.duration) && bgVideo.duration > 0) {
            scheduleByDuration();
          } else {
            bgVideo.addEventListener("loadedmetadata", scheduleByDuration, { once: true });
          }
        }
      };

      const boot = () => {
        const gsap = /** @type {any} */ (window).gsap;
        if (gsap) runHero(gsap);
      };
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", boot, { once: true });
      } else {
        boot();
      }
    </script>
  </body>
</html>
