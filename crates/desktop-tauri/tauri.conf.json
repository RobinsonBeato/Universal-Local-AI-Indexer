{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devPath": "../gui/webpanel",
    "distDir": "../gui/webpanel",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "Lupa Desktop",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "dialog": {
        "all": false,
        "open": true
      },
      "clipboard": {
        "all": false,
        "writeText": true
      },
      "protocol": {
        "all": false,
        "asset": true,
        "assetScope": [
          "**"
        ]
      },
      "shell": {
        "all": false,
        "open": true
      }
    },
    "windows": [
      {
        "title": "Lupa Desktop",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "bundle": {
      "active": true,
      "targets": [
        "nsis",
        "msi"
      ],
      "identifier": "com.lupa.desktop",
      "icon": [
        "icons/main-icon.ico"
      ],
      "copyright": "Copyright (c) 2026 Robinson Beato",
      "category": "Utility",
      "shortDescription": "Ultra-fast local offline search for Windows",
      "longDescription": "LUPA indexes and searches local files offline with a privacy-first architecture."
    },
    "updater": {
      "active": false
    },
    "security": {
      "csp": null
    }
  }
}
